# Azure App Registration (single-tenant quick start)
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
TENANT_NAME=
TENANT_DOMAIN=

# Multi-tenant bootstrap (JSON array string)
TENANTS_JSON=

# Microsoft Graph
GRAPH_API_BASE=https://graph.microsoft.com/v1.0
GRAPH_SCOPE=https://graph.microsoft.com/.default
GRAPH_ACCESS_TOKEN=
ENABLE_LIVE_GRAPH=false
GRAPH_REQUEST_TIMEOUT_MS=10000
GRAPH_MAX_RETRIES=2

# Redis (optional, required for multi-instance consistency)
REDIS_ENABLED=false
REDIS_REQUIRED=false
REDIS_URL=
REDIS_KEY_PREFIX=cam
REDIS_CONNECT_TIMEOUT_MS=5000

# Calendar integration (Outlook via Graph)
ENABLE_CALENDAR_INTEGRATION=false
CALENDAR_TARGET_USER=
CALENDAR_TIMEZONE=UTC
CALENDAR_EVENT_DURATION_MINUTES=30
CALENDAR_STANDARD_REVIEW_DAYS=30
CALENDAR_REPORT_ONLY_REVIEW_DAYS=3
CALENDAR_DISABLED_REVIEW_DAYS=7
CALENDAR_SUMMARY_REVIEW_DAYS=1
CALENDAR_EVENT_HOUR_UTC=9
CALENDAR_EVENT_MINUTE_UTC=0
CALENDAR_CREATE_SUMMARY_REMINDER=true

# Microsoft SSO + RBAC (Entra ID groups)
ENABLE_SSO_LOGIN=false
ENABLE_LOCAL_LOGIN=false
SSO_TENANT_ID=common
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
SSO_REDIRECT_URI=
SSO_POST_LOGOUT_REDIRECT_URI=
SESSION_SECRET=
SESSION_TTL_HOURS=8
SESSION_COOKIE_SECURE=true
AUTH_REQUIRE_GROUPS=true
AUTH_ADMIN_GROUP_IDS=
AUTH_ANALYST_GROUP_IDS=
AUTH_REQUIRE_LOCAL_USER_FOR_SSO=true
AUTH_LOCKOUT_MAX_ATTEMPTS=5
AUTH_LOCKOUT_WINDOW_SECONDS=900
AUTH_LOCKOUT_DURATION_SECONDS=900
AUTH_PASSWORD_MIN_LENGTH=12
AUTH_RATE_LIMIT_WINDOW_SECONDS=900
AUTH_RATE_LIMIT_LOCAL_LOGIN_MAX=12
AUTH_RATE_LIMIT_SSO_MAX=30
AUTH_RATE_LIMIT_ADMIN_MUTATION_MAX=45
AUTH_JSON_BODY_LIMIT_KB=64
LOCAL_USERS_FILE=
LOCAL_BOOTSTRAP_ADMIN_NAME=Local Administrator
LOCAL_BOOTSTRAP_ADMIN_EMAIL=admin@kontoso.com
LOCAL_BOOTSTRAP_ADMIN_PASSWORD=ChangeMeNow123!

# Tamper-aware audit log
AUDIT_LOG_ENABLED=true
AUDIT_LOG_FILE=
AUDIT_LOG_SECRET=

# Key Vault hydration (optional, managed identity)
ENABLE_KEYVAULT_SECRETS=false
KEYVAULT_URL=
KEYVAULT_SECRET_MAPPINGS=
KEYVAULT_OVERRIDE_EXISTING=false
KEYVAULT_TIMEOUT_MS=10000

# App config
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Optional: notification webhook or SMTP for alerts
ALERT_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
